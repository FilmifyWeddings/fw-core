{
  "name": "fw-core-baileys-worker",
  "version": "1.0.0",
  "description": "Persistent Baileys WhatsApp socket worker for FW Core. Runs on Railway/Render/VPS.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc && tsc ../src/lib/queue-processor.ts --outDir ./dist/src/lib/ --target ES2022 --module NodeNext --moduleResolution NodeNext --esModuleInterop --skipLibCheck",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@supabase/supabase-js": "^2.108.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "dotenv": "^16.4.7",
    "link": "^2.1.1",
    "pino": "^9.5.0",
    "pino-pretty": "^12.0.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.3"
  }
}
